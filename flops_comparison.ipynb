   "source": [
    "## Cell 8 — FLOPs vs Input Length Scaling\n",
    "How compute scales with audio duration."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "time_frames = [16, 32, 64, 94, 125, 188, 250]\n",
    "crn_gflops_list = []\n",
    "dpt_gflops_list = []\n",
    "\n",
    "for T in time_frames:\n",
    "    dummy = torch.randn(1, 1, 257, T)\n",
    "    cf, _ = profile(crn, inputs=(dummy,), verbose=False)\n",
    "    df, _ = profile(dpt, inputs=(dummy,), verbose=False)\n",
    "    crn_gflops_list.append(cf / 1e9)\n",
    "    dpt_gflops_list.append(df / 1e9)\n",
    "\n",
    "# Convert frames to seconds (hop=256, sr=16000)\n",
    "durations = [T * 256 / 16000 for T in time_frames]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
    "fig.patch.set_facecolor('#1a1a2e')\n",
    "ax.set_facecolor('#16213e')\n",
    "\n",
    "ax.plot(durations, crn_gflops_list, 'o-', color='#e74c3c', linewidth=2.5,\n",
    "        markersize=8, label='CRN v2 (Baseline)', markeredgecolor='white', markeredgewidth=0.5)\n",
    "ax.plot(durations, dpt_gflops_list, 's-', color='#2ecc71', linewidth=2.5,\n",
    "        markersize=8, label='DPT v2 (Proposed)', markeredgecolor='white', markeredgewidth=0.5)\n",
    "\n",
    "# Annotate the 3s point\n",
    "idx_3s = time_frames.index(188)\n",
    "ax.annotate(f'{crn_gflops_list[idx_3s]:.2f} GFLOPs',\n",
    "            xy=(durations[idx_3s], crn_gflops_list[idx_3s]),\n",
    "            xytext=(durations[idx_3s]+0.3, crn_gflops_list[idx_3s]+0.1),\n",
    "            color='#e74c3c', fontsize=10, fontweight='bold')\n",
    "ax.annotate(f'{dpt_gflops_list[idx_3s]:.2f} GFLOPs',\n",
    "            xy=(durations[idx_3s], dpt_gflops_list[idx_3s]),\n",
    "            xytext=(durations[idx_3s]+0.3, dpt_gflops_list[idx_3s]-0.15),\n",
    "            color='#2ecc71', fontsize=10, fontweight='bold')\n",
    "\n",
    "ax.axvline(3.0, color='#f1c40f', linestyle='--', alpha=0.5, label='3s evaluation window')\n",
    "\n",
    "ax.set_xlabel('Audio Duration (seconds)', color='white', fontsize=12)\n",
    "ax.set_ylabel('GFLOPs per forward pass', color='white', fontsize=12)\n",
    "ax.set_title('Computational Cost vs Audio Duration', color='white', fontsize=14, fontweight='bold')\n",
    "ax.legend(fontsize=11, labelcolor='white', facecolor='#16213e', edgecolor='#444')\n",
    "\n",
    "for sp in ax.spines.values():\n",
    "    sp.set_edgecolor('#444')\n",
    "ax.tick_params(colors='#aaa')\n",
    "ax.grid(color='#333', linewidth=0.7)\n",
    "ax.set_axisbelow(True)\n",
    "\n",
    "plt.savefig('flops_scaling.png', dpi=150, bbox_inches='tight',\n",
    "            facecolor=fig.get_facecolor())\n",
    "plt.show()\n",
    "print(\"Saved: flops_scaling.png\")"
