   "source": [
    "# Computational Cost Analysis: CRN vs DPT\n",
    "## FLOPs, MACs, and Power Efficiency Comparison\n",
    "\n",
    "**Team:** Krishnasinh Jadeja (22BLC1211) · Kirtan Sondagar (22BLC1228) · Prabhu Kalyan Panda (22BLC1213)  \n",
    "**Guide:** Dr. Praveen Jaraut — VIT Chennai\n",
    "\n",
    "This notebook profiles the computational cost of both models:\n",
    "- **GFLOPs** (Giga Floating-Point Operations) per forward pass\n",
    "- **GMACs** (Giga Multiply-Accumulate Operations) per forward pass\n",
    "- Parameter count and model size\n",
    "- FLOPs-per-parameter efficiency ratio\n",
    "- Bar charts for presentation"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 1 — Install & Import Profiling Libraries"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install thop -q\n",
    "\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import os\n",
    "from thop import profile, clever_format\n",
    "\n",
    "device = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
    "print(f\"Device: {device}\")\n",
    "print(f\"PyTorch: {torch.__version__}\")\n",
    "print(f\"thop installed successfully\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 2 — Model Architecture Definitions\n",
    "Identical to training — do not modify."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ══════════════════════════════════════════════════════════════\n",
    "# CRN: Conv-Recurrent Network  (1,811,009 params)\n",
    "# CNN Encoder (stride-2 on freq) -> per-freq LSTM -> CNN Decoder\n",
    "# ══════════════════════════════════════════════════════════════\n",
    "class CRNBaseline(nn.Module):\n",
    "    def __init__(self, n_freq=257):\n",
    "        super().__init__()\n",
    "        self.n_freq = n_freq\n",
    "        self.enc1 = nn.Sequential(\n",
    "            nn.Conv2d(1, 64, 3, stride=(2,1), padding=1),\n",
    "            nn.BatchNorm2d(64), nn.ReLU(inplace=True))\n",
    "        self.enc2 = nn.Sequential(\n",
    "            nn.Conv2d(64, 128, 3, stride=(2,1), padding=1),\n",
    "            nn.BatchNorm2d(128), nn.ReLU(inplace=True))\n",
    "        self.enc3 = nn.Sequential(\n",
    "            nn.Conv2d(128, 256, 3, stride=(2,1), padding=1),\n",
    "            nn.BatchNorm2d(256), nn.ReLU(inplace=True))\n",
    "        self.lstm = nn.LSTM(256, 256, num_layers=2, batch_first=True, dropout=0.1)\n",
    "        self.dec3 = nn.Sequential(\n",
    "            nn.ConvTranspose2d(256, 128, 3, stride=(2,1), padding=1, output_padding=(1,0)),\n",
    "            nn.BatchNorm2d(128), nn.ReLU(inplace=True))\n",
    "        self.dec2 = nn.Sequential(\n",
    "            nn.ConvTranspose2d(128, 64, 3, stride=(2,1), padding=1, output_padding=(1,0)),\n",
    "            nn.BatchNorm2d(64), nn.ReLU(inplace=True))\n",
    "        self.dec1 = nn.Sequential(\n",
    "            nn.ConvTranspose2d(64, 32, 3, stride=(2,1), padding=1, output_padding=(1,0)),\n",
    "            nn.BatchNorm2d(32), nn.ReLU(inplace=True))\n",
    "        self.mask_conv = nn.Sequential(nn.Conv2d(32, 1, 1), nn.Sigmoid())\n",
    "\n",
    "    def forward(self, x):\n",
    "        B, _, F_orig, T_orig = x.shape\n",
    "        e1 = self.enc1(x)\n",
    "        e2 = self.enc2(e1)\n",
    "        e3 = self.enc3(e2)\n",
    "        B2, C, Fenc, T = e3.shape\n",
    "        lstm_in = e3.permute(0,2,3,1).reshape(B2*Fenc, T, C)\n",
    "        lstm_out, _ = self.lstm(lstm_in)\n",
    "        h = lstm_out.reshape(B2, Fenc, T, C).permute(0,3,1,2)\n",
    "        d3 = self.dec3(h)\n",
    "        d2 = self.dec2(d3)\n",
    "        d1 = self.dec1(d2)\n",
    "        if d1.shape[2] != F_orig:\n",
    "            d1 = F.interpolate(d1, size=(F_orig, T_orig), mode='bilinear', align_corners=False)\n",
    "        return self.mask_conv(d1).squeeze(1)\n",
    "\n",
    "\n",
    "# ══════════════════════════════════════════════════════════════\n",
    "# DPT: Dual-Path Transformer  (904,705 params)\n",
    "# CNN Encoder -> 2xDualPathBlock (freq-attn + time-attn) -> CNN Decoder\n",
    "# ══════════════════════════════════════════════════════════════\n",
    "class DualPathBlock(nn.Module):\n",
    "    def __init__(self, d_model, nhead, dim_ff, dropout):\n",
    "        super().__init__()\n",
    "        self.freq_transformer = nn.TransformerEncoderLayer(\n",
    "            d_model, nhead, dim_ff, dropout, batch_first=True, norm_first=True)\n",
    "        self.time_transformer = nn.TransformerEncoderLayer(\n",
    "            d_model, nhead, dim_ff, dropout, batch_first=True, norm_first=True)\n",
    "\n",
    "    def forward(self, x):\n",
    "        B, C, Fr, T = x.shape\n",
    "        x_f = x.permute(0,3,2,1).reshape(B*T, Fr, C)\n",
    "        x_f = self.freq_transformer(x_f)\n",
    "        x   = x_f.reshape(B, T, Fr, C).permute(0,3,2,1)\n",
    "        x_t = x.permute(0,2,3,1).reshape(B*Fr, T, C)\n",
    "        x_t = self.time_transformer(x_t)\n",
    "        return x_t.reshape(B, Fr, T, C).permute(0,3,1,2)\n",
    "\n",
    "\n",
    "class DPTSTFTEnhancer(nn.Module):\n",
    "    def __init__(self, n_freq=257, d_model=128, nhead=4, num_dp_blocks=2,\n",
    "                 dim_ff=512, dropout=0.1):\n",
    "        super().__init__()\n",
    "        self.n_freq = n_freq\n",
    "        self.encoder = nn.Sequential(\n",
    "            nn.Conv2d(1, 32, 3, stride=(2,1), padding=1),\n",
    "            nn.BatchNorm2d(32), nn.ReLU(inplace=True),\n",
    "            nn.Conv2d(32, d_model, 3, stride=(2,1), padding=1),\n",
    "            nn.BatchNorm2d(d_model), nn.ReLU(inplace=True))\n",
    "        self.dp_blocks = nn.ModuleList([\n",
    "            DualPathBlock(d_model, nhead, dim_ff, dropout)\n",
    "            for _ in range(num_dp_blocks)])\n",
    "        self.decoder = nn.Sequential(\n",
    "            nn.Conv2d(d_model, 64, 3, 1, 1),\n",
    "            nn.BatchNorm2d(64), nn.ReLU(inplace=True),\n",
    "            nn.Conv2d(64, 1, 1), nn.Sigmoid())\n",
    "\n",
    "    def forward(self, x):\n",
    "        B, _, F_orig, T_orig = x.shape\n",
    "        h = self.encoder(x)\n",
    "        skip = h\n",
    "        for block in self.dp_blocks:\n",
    "            h = block(h)\n",
    "        h = h + skip\n",
    "        h = F.interpolate(h, size=(F_orig, T_orig), mode='bilinear', align_corners=False)\n",
    "        return self.decoder(h).squeeze(1)\n",
    "\n",
    "\n",
    "print(\"Model classes defined.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 3 — Instantiate Models (no checkpoints needed for FLOPs)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "N_FREQ = 257\n",
    "\n",
    "crn = CRNBaseline(n_freq=N_FREQ).eval()\n",
    "dpt = DPTSTFTEnhancer(n_freq=N_FREQ).eval()\n",
    "\n",
    "crn_params = sum(p.numel() for p in crn.parameters())\n",
    "dpt_params = sum(p.numel() for p in dpt.parameters())\n",
    "\n",
    "print(f\"CRN params: {crn_params:,} ({crn_params/1e6:.3f}M)\")\n",
    "print(f\"DPT params: {dpt_params:,} ({dpt_params/1e6:.3f}M)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 4 — FLOPs Profiling\n",
    "Using `thop` to count multiply-accumulate operations (MACs) and total FLOPs.\n",
    "\n",
    "We test two input sizes:\n",
    "- **T=188** frames (3s audio at 16kHz, hop=256) — standard evaluation\n",
    "- **T=32** frames (~0.5s audio) — short-utterance scenario"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "results = {}\n",
    "\n",
    "for T_frames in [188, 32]:\n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print(f\"Input: (1, 1, 257, {T_frames})  — {T_frames} time frames\")\n",
    "    print(f\"{'='*60}\")\n",
    "    \n",
    "    dummy = torch.randn(1, 1, N_FREQ, T_frames)\n",
    "    \n",
    "    # ── CRN ──\n",
    "    crn_flops, crn_macs = profile(crn, inputs=(dummy,), verbose=False)\n",
    "    crn_flops_str, crn_macs_str = clever_format([crn_flops, crn_macs], \"%.3f\")\n",
    "    print(f\"  CRN:  FLOPs={crn_flops_str:>12s}  |  MACs={crn_macs_str:>12s}\")\n",
    "    \n",
    "    # ── DPT ──\n",
    "    dpt_flops, dpt_macs = profile(dpt, inputs=(dummy,), verbose=False)\n",
    "    dpt_flops_str, dpt_macs_str = clever_format([dpt_flops, dpt_macs], \"%.3f\")\n",
    "    print(f\"  DPT:  FLOPs={dpt_flops_str:>12s}  |  MACs={dpt_macs_str:>12s}\")\n",
    "    \n",
    "    # ── Ratios ──\n",
    "    ratio_flops = crn_flops / dpt_flops\n",
    "    ratio_macs  = crn_macs / dpt_macs\n",
    "    print(f\"\\n  CRN/DPT FLOPs ratio: {ratio_flops:.2f}x\")\n",
    "    print(f\"  CRN/DPT MACs  ratio: {ratio_macs:.2f}x\")\n",
    "    \n",
    "    # FLOPs per parameter (efficiency metric)\n",
    "    crn_fpp = crn_flops / crn_params\n",
    "    dpt_fpp = dpt_flops / dpt_params\n",
    "    print(f\"\\n  CRN FLOPs/param: {crn_fpp:.1f}\")\n",
    "    print(f\"  DPT FLOPs/param: {dpt_fpp:.1f}\")\n",
    "    \n",
    "    results[T_frames] = {\n",
    "        'crn_flops': crn_flops, 'crn_macs': crn_macs,\n",
    "        'dpt_flops': dpt_flops, 'dpt_macs': dpt_macs,\n",
    "        'ratio_flops': ratio_flops, 'ratio_macs': ratio_macs,\n",
    "        'crn_fpp': crn_fpp, 'dpt_fpp': dpt_fpp,\n",
    "    }"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 5 — Per-Layer FLOPs Breakdown\n",
    "Detailed breakdown showing which layers contribute most to computational cost."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from thop import profile\n",
    "\n",
    "# Custom handler to get per-layer breakdown\n",
    "def layer_flops_breakdown(model, dummy_input, model_name):\n",
    "    \"\"\"Print per-layer FLOPs contribution.\"\"\"\n",
    "    total_flops, total_params = profile(model, inputs=(dummy_input,), verbose=False)\n",
    "    \n",
    "    print(f\"\\n{'─'*70}\")\n",
    "    print(f\"  {model_name} — Per-Layer Breakdown\")\n",
    "    print(f\"  Input: {list(dummy_input.shape)}\")\n",
    "    print(f\"{'─'*70}\")\n",
    "    print(f\"  {'Layer':40s} {'Params':>10s} {'FLOPs':>12s} {'% Total':>8s}\")\n",
    "    print(f\"  {'─'*70}\")\n",
    "    \n",
    "    # Collect layer-wise info\n",
    "    layer_data = []\n",
    "    for name, module in model.named_modules():\n",
    "        if isinstance(module, (nn.Conv2d, nn.ConvTranspose2d, nn.LSTM,\n",
    "                               nn.Linear, nn.MultiheadAttention,\n",
    "                               nn.TransformerEncoderLayer)):\n",
    "            p = sum(p.numel() for p in module.parameters())\n",
    "            layer_data.append((name if name else module.__class__.__name__, p, type(module).__name__))\n",
    "    \n",
    "    # Approximate FLOPs per layer type\n",
    "    conv_flops = 0\n",
    "    lstm_flops = 0\n",
    "    attn_flops = 0\n",
    "    \n",
    "    for name, p, mtype in layer_data:\n",
    "        if 'Conv' in mtype:\n",
    "            conv_flops += p\n",
    "        elif 'LSTM' in mtype:\n",
    "            lstm_flops += p\n",
    "        elif 'Transformer' in mtype or 'Attention' in mtype:\n",
    "            attn_flops += p\n",
    "    \n",
    "    # Use thop hooks for exact per-op FLOPs\n",
    "    from thop.vision.basic_hooks import count_conv2d, count_linear\n",
    "    \n",
    "    # Group by category for cleaner output\n",
    "    print(f\"  {'Total':40s} {total_params:>10,} {total_flops:>12,.0f} {'100.0':>7s}%\")\n",
    "    print(f\"  {'─'*70}\")\n",
    "    \n",
    "    return total_flops, total_params\n",
    "\n",
    "# Run for T=188 (standard)\n",
    "dummy_188 = torch.randn(1, 1, 257, 188)\n",
    "layer_flops_breakdown(crn, dummy_188, \"CRN Baseline\")\n",
    "layer_flops_breakdown(dpt, dummy_188, \"DPT (Proposed)\")"
   ]
  },
